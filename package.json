{
  "private": true,
  "description": "The ownCloud documentation (consolidated monorepo)",
  "homepage": "https://github.com/DeepDiver1975/owncloud-docs-monorepo#readme",
  "scripts": {
    "antora": "antora --stacktrace site.yml",
    "antora-local": "antora --stacktrace --url http://localhost:8080 site.yml",
    "pagefind": "pagefind --site public",
    "build": "npm run antora && npm run pagefind",
    "serve": "http-server public/ -d -i",
    "linkcheck": "broken-link-checker --filter-level 3 --recursive --verbose"
  },
  "dependencies": {
    "antora": "^3.1.15",
    "asciidoctor": "^3.0.4",
    "asciidoctor-kroki": "^0.18.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@sntke/antora-mermaid-extension": "^0.0.13",
    "broken-link-checker": "^0.7.8",
    "http-server": "^14.1.1",
    "pagefind": "^1.3.0"
  },
  "overrides": {
    "asciidoctor-opal-runtime": {
      "glob": "~10.4"
    }
  }
}
